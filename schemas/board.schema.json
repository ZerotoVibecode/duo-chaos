{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://duochaos.studio/schemas/board.schema.json",
  "title": "SwarmBoard",
  "type": "object",
  "required": ["tasks"],
  "properties": {
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "publicTitle", "status", "risk", "files"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "publicTitle": { "type": "string", "minLength": 1 },
          "privateTitle": { "type": "string" },
          "publicDescription": { "type": "string" },
          "privateDescription": { "type": "string" },
          "impact": { "enum": ["core", "substantial"] },
          "expectedOutcome": { "type": "string", "minLength": 24, "maxLength": 600 },
          "acceptanceChecks": {
            "type": "array",
            "minItems": 1,
            "maxItems": 4,
            "items": { "type": "string", "minLength": 12, "maxLength": 240 }
          },
          "status": { "enum": ["open", "claimed", "in-progress", "review", "done", "blocked"] },
          "claimedBy": { "enum": ["claude", "codex", "director", "both", "none"] },
          "risk": { "enum": ["low", "medium", "high"] },
          "files": { "type": "array", "items": { "type": "string" } },
          "privateFiles": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
