{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://duochaos.studio/schemas/opinion-event.schema.json",
  "title": "OpinionEvent",
  "type": "object",
  "required": ["id", "type", "runId", "round", "timestamp", "agent", "tone", "heat", "confidence", "publicText", "spoilerRisk", "severity"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "type": { "const": "opinion" },
    "runId": { "type": "string", "minLength": 1 },
    "round": { "type": "integer", "minimum": 0 },
    "timestamp": { "type": "string", "format": "date-time" },
    "agent": { "enum": ["claude", "codex", "director"] },
    "targetAgent": { "enum": ["claude", "codex", "director", "system"] },
    "topic": { "type": "string" },
    "tone": { "enum": ["skeptical", "impressed", "annoyed", "confident", "cautious", "amused", "contrarian", "self-critical", "collaborative", "ruthless"] },
    "heat": { "type": "number", "minimum": 0, "maximum": 1 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "severity": { "enum": ["low", "medium", "high", "critical"] },
    "publicText": { "type": "string", "minLength": 1 },
    "privateText": { "type": "string" },
    "spoilerRisk": { "type": "number", "minimum": 0, "maximum": 1 },
    "evidenceFiles": { "type": "array", "items": { "type": "string" } },
    "relatedTaskIds": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
