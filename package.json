{
  "name": "duo-chaos",
  "version": "0.1.0",
  "description": "A local desktop war room where Codex and Claude Code debate, build, review, and repair both surprise experiments and serious products together.",
  "main": "./out/main/index.js",
  "type": "module",
  "private": true,
  "license": "MIT",
  "author": "ZeroToVibecode",
  "repository": {
    "type": "git",
    "url": "https://github.com/ZeroToVibecode/duo-chaos.git"
  },
  "homepage": "https://github.com/ZeroToVibecode/duo-chaos#readme",
  "bugs": {
    "url": "https://github.com/ZeroToVibecode/duo-chaos/issues"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "benchmark:receipts": "node scripts/benchmark-run-receipts.mjs",
    "benchmark:quality": "node scripts/benchmark-quality-per-token.mjs",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "icons": "node scripts/generate-icon.mjs",
    "check": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/manrope": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "cross-spawn": "^7.0.6",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^22.18.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.10",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  },
  "keywords": [
    "ai-agents",
    "codex",
    "claude-code",
    "electron",
    "react",
    "local-first",
    "multi-agent"
  ],
  "build": {
    "appId": "com.zerotovibecode.duochaos",
    "productName": "Duo Chaos",
    "artifactName": "Duo-Chaos-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "schemas/**/*",
      "resources/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools",
      "icon": "resources/icon.png"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Development",
      "icon": "resources/icon.png"
    }
  }
}
